# 小兰 v1 —— API Key 配置
# 使用方法：
#   1. cp .env.example .env
#   2. 编辑 .env，把用到的模型对应的 Key 填上（不用的行留着占位符即可）
#   3. 程序内输入 /model 即可在已配置 Key 的模型间切换
# 说明：若 小兰V0/.env 里已存过 ANTHROPIC_API_KEY（Kimi），v1 会自动沿用，
#       本文件可以只补充其他平台的 Key。

# 默认启动模型（可选：kimi-k3 / deepseek-chat / glm-4.6）
MODEL_NAME=kimi-k3

# Kimi（platform.moonshot.cn → API Keys 页面创建）
MOONSHOT_API_KEY=sk-xxx

# DeepSeek（platform.deepseek.com → API Keys 页面创建）
DEEPSEEK_API_KEY=sk-xxx

# 智谱 GLM（open.bigmodel.cn → API 管理页面创建）
ZHIPU_API_KEY=sk-xxx
