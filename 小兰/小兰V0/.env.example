# 小兰 v0 —— Kimi API 配置
# 使用方法：
#   1. 复制本文件为 .env：        cp .env.example .env
#   2. 用编辑器打开 .env：        nano .env   （或 code .env）
#   3. 把 sk-xxx 替换成你的 Kimi API Key（在 platform.moonshot.cn 的
#      「API Keys」页面创建），保存退出。
# .env 已加入 .gitignore，不会被提交到 git。

ANTHROPIC_API_KEY=sk-xxx
ANTHROPIC_BASE_URL=https://api.moonshot.cn/anthropic
MODEL_NAME=kimi-k3
